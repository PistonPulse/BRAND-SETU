# ─── BrandSetu Frontend — Production Environment ─────────────
# Copy this file as `.env.production` and fill in your real values.
# Vite injects these at BUILD TIME — they are embedded in the JS bundle.
# NEVER put truly secret values here (they end up in client-side code).

# Backend API (your Lambda API Gateway URL + /api/v1)
VITE_API_URL=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com/api/v1

# API Key (shared with backend for X-API-Key header)
VITE_API_KEY=your-api-key

# Supabase (anon key only — safe for client-side)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
