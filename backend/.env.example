# ─── BrandSetu Backend Environment Variables ─────────────────
# Copy this file as `.env` and fill in your real values.
# NEVER commit the `.env` file to version control.

# App
PROJECT_NAME=BrandSetu API
APP_VERSION=0.1.0
ENVIRONMENT=development

# API
API_V1_STR=/api/v1

# CORS (comma-separated origins for production)
BACKEND_CORS_ORIGINS=["http://localhost:5173"]

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# Groq (primary LLM)
GROQ_API_KEY=gsk_your-groq-api-key

# AWS Bedrock (fallback LLM)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1

# LLM tuning
DEFAULT_GROQ_MODEL=llama-3.3-70b-versatile
DEFAULT_BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=4096

# API Key (for X-API-Key header protection)
API_KEY=your-server-api-key
